{
  "apiKeyHelper": "~/.claude/bin/get-api-key.sh",
  "fileSuggestion": {
    "type": "command",
    "command": "~/.claude/bin/file-suggestions.sh"
  },
  "env": {
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./*.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)",
      "Read(./notes.md)",
      "Read(./.terraform/**)",
      "Read(./.venv/**)",
      "Read(./build/**)",
      "Read(./node_modules/**)",
      "Read(./renv/**)",
      "Read(./venv/**)",
      "Read(./worktrees/**)",
      "Bash(terraform plan:*)",
      "Bash(terraform apply:*)"
    ]
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/prek-stop-hook.sh",
            "asyncRewake": true,
            "rewakeSummary": "prek hooks reported issues",
            "statusMessage": "Running prek hooks"
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "editorMode": "vim",
  "preferredNotifChannel": "ghostty"
}
