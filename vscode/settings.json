{
    "cSpell.customDictionaries": {
        "vim-dict": {
            "name": "vim-dict",
            "path": "~/dotfiles/spell/en.utf-8.add",
            "description": "Words sourced from vim dictionary",
            "addWords": true
        }
    },
    "cSpell.enableFiletypes": [
        "*",
        "!json",
        "!jsonc"
    ],
    "editor.fontFamily": "'JetBrainsMono Nerd Font', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.suggestSelection": "first",
    "explorer.confirmDelete": false,
    "git.autofetch": true,
    "git.autofetchPeriod": 900,
    "git.enableCommitSigning": true,
    "git.fetchOnPull": true,
    "github.gitProtocol": "ssh",
    "path-intellisense.showHiddenFiles": true,
    "python.defaultInterpreterPath": "/usr/bin/python3",
    "scm.alwaysShowActions": true,
    "scm.alwaysShowRepositories": true,
    "security.promptForLocalFileProtocolHandling": false,
    "security.workspace.trust.startupPrompt": "never",
    "terminal.integrated.defaultProfile.osx": "bash",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font, monospace",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.profiles.osx": {
        "bash": {
            "path": "bash",
            "args": [
                "-l"
            ],
            "icon": "terminal-bash"
        },
        "tmux": {
            "path": "tmux",
            "icon": "terminal-tmux"
        }
    },
    "terminal.integrated.shellIntegration.suggestEnabled": true,
    "telemetry.telemetryLevel": "off",
    "vim.easymotion": true,
    "vim.easymotionKeys": "hklyuiopnmqwertzxcvbasdgjf",
    "vim.foldfix": true,
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.color": "rgba(137, 220, 235, 0.25)",
    "vim.highlightedyank.duration": 700,
    "vim.leader": ",",
    "vim.normalModeKeyBindings": [
        // Zero goes to first character
        {
            "before": [
                "0"
            ],
            "after": [
                "^"
            ]
        },
        // Space starts easymotion port
        {
            "before": [
                "<space>"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "s"
            ]
        },
        {
            "before": [
                "<leader>",
                "c"
            ],
            "commands": [
                "editor.action.commentLine"
            ]
        },
        {
            "before": [
                "<leader>",
                "<space>",
            ],
            "commands": [
                "editor.toggleFold"
            ]
        },
        // Replace vim command and search with VSCode built-ins
        {
            "before": [
                ":"
            ],
            "commands": [
                "workbench.action.showCommands",
            ],
            "silent": true
        },
        {
            "before": [
                "<leader>",
                "w"
            ],
            "commands": [
                "workbench.action.files.save",
            ]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "U"
            ],
            "commands": [
                "redo"
            ]
        },
        {
            "before": [
                "<BS>"
            ],
            "after": [
                "{"
            ]
        },
        {
            "before": [
                "<CR>"
            ],
            "after": [
                "}"
            ]
        },
        {
            "before": [
                "R"
            ],
            "after": [
                "d",
                "i",
                "w",
                "\"",
                "0",
                "P"
            ]
        },
        // Copy and paste with system clipboard
        {
            "before": [
                "<leader>",
                "y"
            ],
            "after": [
                "\"",
                "+",
                "y"
            ]
        },
        {
            "before": [
                "<leader>",
                "y",
                "y"
            ],
            "after": [
                "\"",
                "+",
                "y",
                "y"
            ]
        },
        {
            "before": [
                "<leader>",
                "p"
            ],
            "after": [
                "\"",
                "+",
                "p"
            ]
        },
        {
            "before": [
                "<leader>",
                "P"
            ],
            "after": [
                "\"",
                "+",
                "P"
            ]
        },
    ],
    "vim.visualModeKeyBindings": [
        {
            "before": [
                "<space>"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "s"
            ]
        },
        {
            "before": [
                "<leader>",
                "c"
            ],
            "commands": [
                "editor.action.commentLine"
            ]
        },
        // Use VSCode < and > to indent and outdent
        {
            "before": [
                ">"
            ],
            "commands": [
                "editor.action.indentLines"
            ]
        },
        {
            "before": [
                "<"
            ],
            "commands": [
                "editor.action.outdentLines"
            ]
        },
        // Don't move cursor after yank
        {
            "before": [
                "y"
            ],
            "after": [
                "y",
                "g",
                "v",
                "<esc>"
            ]
        },
        // Copy and paste with system clipboard
        {
            "before": [
                "<leader>",
                "y"
            ],
            "after": [
                "\"",
                "+",
                "y",
                "g",
                "v",
                "<esc>"
            ]
        },
    ],
    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<BS>"
            ],
            "after": [
                "{"
            ]
        },
        {
            "before": [
                "<CR>"
            ],
            "after": [
                "}"
            ]
        },
        // Replace word with last yank 
        {
            "before": [
                "R"
            ],
            "after": [
                "\"",
                "_",
                "d",
                "\"",
                "0",
                "P",
                "\"",
            ]
        },
        {
            "before": [
                "<leader>",
                "p"
            ],
            "after": [
                "\"",
                "+",
                "p"
            ]
        },
        {
            "before": [
                "<leader>",
                "P"
            ],
            "after": [
                "\"",
                "+",
                "P"
            ]
        },
    ],
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.preferredDarkColorTheme": "Catppuccin Mocha",
}